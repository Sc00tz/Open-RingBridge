# Copy this to .env and fill in your values, then `docker-compose up -d`.
# These are read once on first run to seed the settings table; afterwards the
# values stored in the DB take precedence (edit them from the admin panel).

# Admin panel password. CHANGE THIS — the server logs a warning if left as 'changeme'.
ADMIN_PASSWORD=changeme

# Key the Android app must present to register a device. CHANGE THIS.
REGISTRATION_KEY=changeme

# Secret used to sign admin login session cookies. CHANGE THIS to a long random
# string (e.g. `openssl rand -hex 32`) — a default/blank value makes sessions forgeable.
SESSION_SECRET=change-this-secret-in-production

# Base URL the app should sync to, e.g. http://192.168.1.10:8080
# Embedded in the device-pairing QR code generated by the admin panel.
SERVER_URL=

# Path to the SQLite database file inside the container (mounted volume).
# Defaults to /data/ringbridge.db; only change if you remap the volume.
# DATABASE_PATH=/data/ringbridge.db

# ── InfluxDB / MQTT forwarding ──────────────────────────────────────────────
# NOT configured here — these are set from the admin panel (Settings page) and
# stored in the database, not read from environment variables.
