<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Status card ──────────────────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/status_idle">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BioLocal Ring Bridge"
                        android:textSize="10sp"
                        android:letterSpacing="0.10"
                        android:textColor="#AAFFFFFF" />

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Idle"
                        android:textSize="22sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:layout_marginTop="2dp" />

                </LinearLayout>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnToggle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Start"
                    app:cornerRadius="24dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Compact readiness strip ──────────────────────────────────────── -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardReadiness"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:padding="16dp">

                <dev.ringbridge.ReadinessGaugeView
                    android:id="@+id/gaugeReadiness"
                    android:layout_width="96dp"
                    android:layout_height="96dp" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="16dp"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="READINESS"
                        android:textSize="11sp"
                        android:letterSpacing="0.15"
                        android:textColor="@color/section_label_color" />

                    <TextView
                        android:id="@+id/tvReadinessLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="—"
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="?android:attr/textColorPrimary"
                        android:layout_marginTop="2dp" />

                    <TextView
                        android:id="@+id/tvReadinessSub"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text=""
                        android:textSize="12sp"
                        android:textColor="@color/section_label_color"
                        android:layout_marginTop="4dp" />

                </LinearLayout>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- ── Metric grid (2 columns) ──────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_metric_card" android:id="@+id/cardHr"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_metric_card" android:id="@+id/cardSpo2"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_metric_card" android:id="@+id/cardBp"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_metric_card" android:id="@+id/cardHrv"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_metric_card" android:id="@+id/cardStress"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_metric_card" android:id="@+id/cardGlucose"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false">

            <include layout="@layout/view_metric_card" android:id="@+id/cardSteps"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_metric_card" android:id="@+id/cardBattery"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
