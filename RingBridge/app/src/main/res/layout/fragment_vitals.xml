<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- ── Section: VITALS ──────────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="VITALS"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="@color/section_label_color"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <!-- Row: Heart Rate + SpO₂ -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_vitals_card" android:id="@+id/cardHr"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_vitals_card" android:id="@+id/cardSpo2"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        </LinearLayout>

        <!-- Blood Pressure (full width — needs room for sys/dia) -->
        <include layout="@layout/view_vitals_card" android:id="@+id/cardBp"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

        <!-- Row: Battery + Blood Glucose -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_vitals_card" android:id="@+id/cardBattery"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_vitals_card" android:id="@+id/cardGlucose"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        </LinearLayout>

        <!-- ── Section: RECOVERY ───────────────────────────────────────────── -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="RECOVERY"
            android:textSize="11sp"
            android:letterSpacing="0.15"
            android:textColor="@color/section_label_color"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="8dp"
            android:layout_marginStart="4dp" />

        <!-- Row: HRV + Stress -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:baselineAligned="false"
            android:layout_marginBottom="8dp">

            <include layout="@layout/view_vitals_card" android:id="@+id/cardHrv"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
            <Space android:layout_width="8dp" android:layout_height="1dp" />
            <include layout="@layout/view_vitals_card" android:id="@+id/cardStress"
                android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" />
        </LinearLayout>

        <!-- Respiratory Rate (full width) -->
        <include layout="@layout/view_vitals_card" android:id="@+id/cardResp"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginBottom="8dp" />

    </LinearLayout>
</ScrollView>
